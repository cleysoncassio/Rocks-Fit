# ============================================================
#  .env.example — Modelo de variáveis de ambiente
#  Copie para .env e preencha com seus valores.
# ============================================================

# Chave secreta do Django (obrigatória em produção)
SECRET_KEY=sua-chave-secreta-aqui

# [PRODUÇÃO] URL de conexão com PostgreSQL
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# [PRODUÇÃO] Hosts permitidos (separados por vírgula)
# ALLOWED_HOSTS=academiarocksfit.com.br,www.academiarocksfit.com.br,.hostman.site

# [PRODUÇÃO] CSRF Trusted Origins
# CSRF_TRUSTED_ORIGINS=https://academiarocksfit.com.br,https://www.academiarocksfit.com.br

# [OPCIONAL] Stone/InfinitePay
# STONE_SECRET_KEY=sk_live_sua_chave

# [OPCIONAL] API Key genérica
# API_KEY=sua_api_key
