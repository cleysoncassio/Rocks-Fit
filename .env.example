# ============================================================
#  .env.example — MODELO DE VARIÁVEIS DE AMBIENTE
#  Copie este arquivo para .env e preencha os valores.
# ============================================================

# Chave Secreta do Django (Gere uma nova para produção)
SECRET_KEY=sua-chave-secreta-aqui

# Configuração de Banco de Dados (Apenas para Produção ou se usar Postgres no Dev)
# Exemplo: postgresql://usuario:senha@localhost:5432/nome_do_banco
DATABASE_URL=

# Configurações Adicionais (Opcional no Dev)
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Chaves de API de terceiros
STONE_SECRET_KEY=sk_test_...

# Variável para forçar o ambiente caso necessário (manage.py já tem default)
# DJANGO_SETTINGS_MODULE=sitio.settings.development
